<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0A">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎮 FF PANEL VIP"
            android:textColor="#BB86FC"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="2dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Anti Banned | Safe Inject"
            android:textColor="#888888"
            android:textSize="11sp"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🔑 LICENSE KEY"
            android:textColor="#BB86FC"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp"/>

        <EditText
            android:id="@+id/keyInput"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="Masukkan key lisensi"
            android:textColor="#FFFFFF"
            android:textColorHint="#666666"
            android:background="#1A1A1A"
            android:padding="12dp"
            android:layout_marginBottom="14dp"
            android:inputType="textCapCharacters"/>

        <Button
            android:id="@+id/btnActivate"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="MULAI PANEL"
            android:textColor="#0A0A0A"
            android:background="#BB86FC"
            android:textStyle="bold"
            android:textSize="15sp"
            android:layout_marginBottom="10dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🔓 Key Gratis: FFFREE"
            android:textColor="#FFD700"
            android:textSize="11sp"
            android:gravity="center"
            android:layout_marginBottom="6dp"/>

        <TextView
            android:id="@+id/loadingText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#AAAAAA"
            android:textSize="12sp"
            android:layout_marginBottom="10dp"
            android:visibility="gone"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#222222"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="✦ FITUR PANEL ✦"
            android:textColor="#BB86FC"
            android:textSize="14sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="10dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="✅ Aimlock (Auto Headshot)\n✅ Wallhack (Tembus Tembok)\n✅ Esp Line + Box\n✅ Antena (Deteksi Musuh)\n✅ No Recoil (0% Getaran)\n✅ Speed Hack (Lari Cepat)\n✅ Unlimited Ammo (Peluru Tak Terbatas)\n✅ No Grass (Rumput Hilang)\n✅ Ghost Mode (Ga Keliatan)"
            android:textColor="#CCCCCC"
            android:textSize="12sp"
            android:lineSpacingExtra="5dp"
            android:layout_marginBottom="12dp"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#222222"
            android:layout_marginBottom="10dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📊 STATUS INJECT"
            android:textColor="#BB86FC"
            android:textSize="11sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp"/>

        <TextView
            android:id="@+id/statusBypass"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#888888"
            android:textSize="12sp"
            android:text="⏳ Sistem Bypass: MENUNGGU"/>

        <TextView
            android:id="@+id/statusAimlock"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#888888"
            android:textSize="12sp"
            android:text="⏳ Aimlock: MENUNGGU"
            android:layout_marginTop="4dp"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#222222"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="10dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⚠️ PERHATIAN"
            android:textColor="#FF4444"
            android:textSize="11sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="• Dilarang keras jual beli panel ini\n• Melanggar = banned permanen"
            android:textColor="#888888"
            android:textSize="10sp"
            android:lineSpacingExtra="3dp"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📢 UPDATE v7.0"
            android:textColor="#BB86FC"
            android:textSize="11sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="• Fix detection Garena\n• Tambah fitur Ghost Mode\n• Optimasi performa\n• Anti ban system updated"
            android:textColor="#666666"
            android:textSize="10sp"
            android:lineSpacingExtra="3dp"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#6200EE"
            android:textSize="11sp"
            android:text="By: FF Tools"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#444444"
            android:textSize="9sp"
            android:text="Version 7.0 | Safe Inject | Anti Banned"/>

    </LinearLayout>
</ScrollView>